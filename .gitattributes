# Normalise line endings to LF in the repo, CRLF on Windows checkout
* text=auto eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.csv text eol=lf
*.txt text eol=lf

# Binaries — never touch
*.pdf binary
*.docx binary
*.faiss binary
